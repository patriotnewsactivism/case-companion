# Database Connection
DATABASE_URL="postgresql://postgres:[password]@[host]:5432/postgres"

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Google Drive Integration
# Get these from Google Cloud Console: https://console.cloud.google.com/
# See GOOGLE_DRIVE_SETUP.md for detailed setup instructions
VITE_GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
VITE_GOOGLE_API_KEY="your-google-api-key"

# Azure Computer Vision API (PRIMARY OCR - BEST QUALITY)
# FREE: 5,000 requests/month, industry-leading accuracy
# Get from: https://portal.azure.com → Create "Computer Vision" resource
AZURE_VISION_ENDPOINT="https://your-resource.cognitiveservices.azure.com/"
AZURE_VISION_API_KEY="your-azure-api-key"

# OCR.space API (FALLBACK OCR - RELIABLE)
# FREE: 25,000 requests/month with no credit card required
# Automatically used if Azure fails or hits rate limits
# Get from: https://ocr.space/ocrapi (click "Register for free API key")
OCR_SPACE_API_KEY="your-ocr-space-api-key"

# Google AI API (LAST RESORT OCR - OPTIONAL)
# FREE: 1,500 requests/day free tier
# Only used if both Azure and OCR.space fail
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY="your-google-ai-api-key"

# OpenAI API (for AI features - OPTIONAL for transcription)
# Note: Audio/video transcription now uses AssemblyAI (see below)
# Still used for other AI features like document analysis
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key"
VITE_OPENAI_API_KEY="sk-your-openai-api-key"
VITE_OPENAI_MODEL_HEAVY="claude-sonnet-4-20250514"
VITE_OPENAI_MODEL_FAST="gpt-4o-mini"
VITE_WHISPER_ENABLED="true"

# AssemblyAI API (for audio/video transcription)
# Required for transcribing audio and video files
# Uses Universal-3 Pro model with speaker diarization, entity detection, and summarization
# FREE: 5 hours of transcription/month (no credit card required)
# Get from: https://www.assemblyai.com
ASSEMBLYAI_API_KEY="your-assemblyai-api-key"

# Daily.co API (for video conferencing)
# Required for creating and managing video rooms
# Get from: https://dashboard.daily.co/
DAILY_API_KEY="your-daily-api-key"

# Daily.co Webhook Secret (optional - for webhook signature verification)
# Set this in production to verify webhook authenticity
DAILY_WEBHOOK_SECRET="your-webhook-secret"

# ─────────────────────────────────────────────────────────────────
# VOICE COURTROOM (Supabase secrets — set via CLI, NOT in .env)
# Run: npx supabase secrets set KEY=value
# ─────────────────────────────────────────────────────────────────

# Deepgram Nova-3 — Real-time courtroom speech-to-text
# FREE: 45,000 minutes/year, no credit card for free tier
# Get from: https://console.deepgram.com → API Keys
# Secret name: DEEPGRAM_API_KEY
# npx supabase secrets set DEEPGRAM_API_KEY=your-key

# ElevenLabs — Per-character TTS voices (judge, witness, counsel, etc.)
# FREE: 10,000 chars/month
# Get from: https://elevenlabs.io → Profile → API Keys
# Secret name: ELEVENLABS_API_KEY
# npx supabase secrets set ELEVENLABS_API_KEY=your-key

# Google AI (Gemini 2.5 Pro) — Primary LLM for all AI features
# FREE: Generous free tier via Google AI Studio
# Get from: https://aistudio.google.com/app/apikey
# Secret name: GOOGLE_AI_API_KEY
# npx supabase secrets set GOOGLE_AI_API_KEY=your-key
